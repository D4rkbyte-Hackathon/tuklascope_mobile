.vscode/
*.swp
*.swo
*.iml

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Monorepo specific environment variables
.env

# Note: Language-specific ignores (Dart/Flutter, Python) 
# should remain in their respective mobile/.gitignore and backend/.gitignore files.